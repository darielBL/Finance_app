<%= form_with model: income, local: true do |f| %>
  <% if income.errors.any? %>
    <div class="alert alert-danger">
      <h4><%= pluralize(income.errors.count, "error") %></h4>
      <ul><% income.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %></ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :name, "Nombre", class: "form-label" %>
    <%= f.text_field :name, class: "form-control", required: true, placeholder: "Ej: Salario, Venta de laptop, Freelance" %>
  </div>

  <div class="row">
    <div class="col-md-6 mb-3">
      <%= f.label :normalized_amount, "Monto", class: "form-label" %>
      <%= f.number_field :normalized_amount,
                         class: "form-control",
                         step: 0.01,
                         required: true,
                         placeholder: "0.00",
                         value: income.normalized_amount %>
    </div>
    <div class="col-md-6 mb-3">
      <%= f.label :amount_currency, "Moneda", class: "form-label" %>
      <%= f.select :amount_currency, ["CUP", "USD", "EUR", "MXN"], {}, class: "form-select" %>
    </div>
  </div>

  <div class="mb-3">
    <%= f.label :source, "Origen del dinero", class: "form-label" %>
    <%= f.text_field :source,
                     list: "source_options",
                     class: "form-control",
                     placeholder: "Ej: Efectivo, Tarjeta BBVA, Transferencia, PayPal",
                     required: true %>
    <datalist id="source_options">
      <% current_user.incomes.distinct.pluck(:source).compact.each do |source| %>
        <option value="<%= source %>">
      <% end %>
    </datalist>
    <small class="text-muted">Puedes escribir cualquier origen. Los usados anteriormente aparecerán como sugerencias.</small>
  </div>

  <div class="mb-3 form-check">
    <%= f.check_box :recurring, class: "form-check-input", data: { action: "toggle-recurring" } %>
    <%= f.label :recurring, "Ingreso recurrente", class: "form-check-label" %>
  </div>

  <div id="recurring-income-fields">
    <div class="mb-3">
      <%= f.label :due_day, "Día de cobro", class: "form-label" %>
      <%= f.select :due_day,
                   [["Cualquier día", ""]] + (1..31).map { |d| ["Día #{d}", d] },
                   {},
                   class: "form-select" %>
      <small class="text-muted">¿Qué día del mes sueles recibir este ingreso?</small>
    </div>

    <div class="mb-3">
      <div class="form-check">
        <%= f.check_box :active, class: "form-check-input" %>
        <%= f.label :active, "Activo", class: "form-check-label" %>
      </div>
      <small class="text-muted">Si está activo, este ingreso se considerará en tus cálculos mensuales</small>
    </div>
  </div>

  <%= f.hidden_field :amount_cents %>

  <%= f.submit income.new_record? ? "Guardar Ingreso" : "Actualizar Ingreso", class: "btn btn-primary" %>
  <%= link_to "Cancelar", incomes_path, class: "btn btn-secondary" %>
<% end %>

<script>
  (function() {
    var checkbox = document.querySelector('[data-action="toggle-recurring"]');
    var recurringFields = document.getElementById('recurring-income-fields');

    function toggleFields() {
      recurringFields.style.display = checkbox.checked ? 'block' : 'none';
    }

    if (checkbox) {
      checkbox.addEventListener('change', toggleFields);
      toggleFields();
    }
  })();
</script>
