<div class="d-flex justify-content-between align-items-center mb-4">
  <h1><i class="fas fa-bell me-2"></i>Notificaciones</h1>
  <% if @notifications.unread.any? %>
    <%= button_to mark_all_as_read_notifications_path, method: :patch, class: "btn btn-outline-primary btn-sm", form: { style: "display: inline;" } do %>
      <i class="fas fa-check-double me-1"></i>Marcar todas como le\u00eddas
    <% end %>
  <% end %>
</div>

<% if @notifications.any? %>
  <div class="list-group">
    <% @notifications.each do |notification| %>
      <div class="list-group-item list-group-item-action d-flex justify-content-between align-items-start <%= 'list-group-item-secondary' unless notification.read %>">
        <div class="ms-2 me-auto">
          <div class="fw-bold">
            <% if notification.notifiable.is_a?(Income) %>
              <i class="fas fa-dollar-sign text-success me-1"></i>
            <% else %>
              <i class="fas fa-shopping-cart text-warning me-1"></i>
            <% end %>
            <%= notification.title %>
          </div>
          <small class="text-muted"><%= notification.message %></small>
          <br>
          <small class="text-muted"><%= time_ago_in_words(notification.created_at) %></small>
        </div>
        <div class="d-flex gap-1">
          <% unless notification.read %>
            <%= button_to notification_path(notification), method: :patch, class: "btn btn-sm btn-outline-primary", form: { style: "display: inline;" } do %>
              <i class="fas fa-check"></i>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="text-center py-5">
    <i class="fas fa-bell fa-3x text-muted mb-3"></i>
    <p class="text-muted">No tienes notificaciones.</p>
  </div>
<% end %>
