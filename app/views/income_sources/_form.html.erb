<%= form_with model: income_source, local: true do |f| %>
  <% if income_source.errors.any? %>
    <div class="alert alert-danger">
      <h4><%= pluralize(income_source.errors.count, "error") %></h4>
      <ul><% income_source.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %></ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :name, "Nombre", class: "form-label" %>
    <%= f.text_field :name, class: "form-control", required: true, placeholder: "Ej: Venta de laptop, Bono, Regalo" %>
  </div>

  <div class="row">
    <div class="col-md-6 mb-3">
      <%= f.label :normalized_amount, "Monto", class: "form-label" %>
      <%= f.number_field :normalized_amount,
                         class: "form-control",
                         step: 0.01,
                         required: true,
                         placeholder: "0.00",
                         value: income_source.normalized_amount %>
    </div>
    <div class="col-md-6 mb-3">
      <%= f.label :amount_currency, "Moneda", class: "form-label" %>
      <%= f.select :amount_currency, ["CUP", "USD", "EUR", "MXN"], {}, class: "form-select" %>
    </div>
  </div>

  <div class="mb-3">
    <%= f.label :source, "Origen del dinero", class: "form-label" %>
    <%= f.text_field :source,
                     list: "source_options",
                     class: "form-control",
                     placeholder: "Ej: Efectivo, Tarjeta BBVA, Transferencia, PayPal",
                     required: true %>
    <datalist id="source_options">
      <% current_user.income_sources.distinct.pluck(:source).compact.each do |source| %>
        <option value="<%= source %>">
      <% end %>
      <% current_user.recurring_incomes.distinct.pluck(:source).compact.each do |source| %>
        <option value="<%= source %>">
      <% end %>
    </datalist>
    <small class="text-muted">Puedes escribir cualquier origen. Los usados anteriormente aparecerán como sugerencias.</small>
  </div>

  <%= f.hidden_field :amount_cents %>

  <%= f.submit "Guardar Ingreso", class: "btn btn-primary" %>
  <%= link_to "Cancelar", income_sources_path, class: "btn btn-secondary" %>
<% end %>