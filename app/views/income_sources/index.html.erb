<h1 class="mb-4">Gestión de Ingresos</h1>

<!-- Tabs -->
<ul class="nav nav-tabs mb-4" id="incomeTabs" role="tablist">
  <li class="nav-item" role="presentation">
    <button class="nav-link active" id="unique-tab" data-bs-toggle="tab" data-bs-target="#unique" type="button" role="tab">
      <i class="fas fa-receipt me-1"></i> Ingresos Únicos
    </button>
  </li>
  <li class="nav-item" role="presentation">
    <button class="nav-link" id="recurring-tab" data-bs-toggle="tab" data-bs-target="#recurring" type="button" role="tab">
      <i class="fas fa-calendar-alt me-1"></i> Ingresos Recurrentes
    </button>
  </li>
</ul>

<!-- Contenido de tabs -->
<div class="tab-content">
  <!-- Pestaña: Ingresos Únicos -->
  <div class="tab-pane fade show active" id="unique" role="tabpanel">
    <div class="mb-3">
      <%= link_to new_income_source_path, class: "btn btn-primary" do %>
        <i class="fas fa-plus me-1"></i>Nuevo Ingreso Único
      <% end %>
    </div>
    <%= render "income_sources_table", income_sources: @income_sources %>
  </div>

  <!-- Pestaña: Ingresos Recurrentes -->
  <div class="tab-pane fade" id="recurring" role="tabpanel">
    <div class="mb-3">
      <%= link_to new_recurring_income_path, class: "btn btn-outline-primary" do %>
        <i class="fas fa-plus me-1"></i>Nuevo Ingreso Recurrente
      <% end %>
    </div>
    <%= render "recurring_incomes_table", recurring_incomes: @recurring_incomes %>
  </div>
</div>