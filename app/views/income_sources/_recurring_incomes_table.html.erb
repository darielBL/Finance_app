<div class="table-responsive">
  <table class="table table-striped">
    <thead>
    <tr>
      <th>Ingreso</th>
      <th class="text-end">Mensual</th>
      <th>Día</th>
      <th class="text-end">Mes actual</th>
      <th>Estado</th>
      <th class="text-end">Acciones</th>
    </tr>
    </thead>
    <tbody>
    <% recurring_incomes.each do |income| %>
      <% current_record = income.current_month_record %>
      <tr>
        <td><i class="fas fa-sync-alt text-success me-2"></i><%= income.name %></td>
        <td class="text-end"><%= income.estimated_amount.format %></td>
        <td><%= income.due_day.present? ? "Día #{income.due_day}" : "Variable" %></td>
        <td class="text-end">
          <% if current_record&.actual_amount_cents %>
            <%= Money.new(current_record.actual_amount_cents, current_record.actual_amount_currency).format %>
          <% else %>
            <span class="badge bg-warning">Pendiente</span>
          <% end %>
        </td>
        <td>
          <% if current_record&.actual_amount_cents %>
            <% diff = current_record.actual_amount_cents - income.estimated_amount_cents %>
            <% if diff > 0 %>
              <span class="badge bg-success">+<%= Money.new(diff, current_record.actual_amount_currency).format %></span>
            <% elsif diff < 0 %>
              <span class="badge bg-warning"><%= Money.new(diff, current_record.actual_amount_currency).format %></span>
            <% else %>
              <span class="badge bg-info">Cumplido</span>
            <% end %>
          <% else %>
            <span class="badge bg-secondary">Sin registrar</span>
          <% end %>
        </td>
        <td class="text-nowrap text-end">
          <%= link_to edit_recurring_income_path(income), class: "btn btn-sm btn-outline-primary me-1", title: "Editar" do %>
            <i class="fas fa-edit"></i>
          <% end %>
          <%= link_to new_recurring_income_recurring_income_record_path(income, month: Date.current.beginning_of_month), class: "btn btn-sm btn-outline-info me-1", title: "Registrar ingreso" do %>
            <i class="fas fa-receipt"></i>
          <% end %>
          <%= button_to recurring_income_path(income), method: :delete, class: "btn btn-sm btn-outline-danger", title: "Eliminar", form: { class: "d-inline" }, data: { turbo_confirm: "¿Eliminar este ingreso recurrente?" } do %>
            <i class="fas fa-trash-alt"></i>
          <% end %>
        </td>
      </tr>
    <% end %>
    </tbody>
  </table>
</div>