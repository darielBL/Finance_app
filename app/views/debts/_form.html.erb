<%= form_with model: debt, local: true do |f| %>
  <% if debt.errors.any? %>
    <div class="alert alert-danger">
      <h4><%= pluralize(debt.errors.count, "error") %> impidieron guardar esta deuda:</h4>
      <ul>
        <% debt.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :name, "Concepto", class: "form-label" %>
    <%= f.text_field :name, class: "form-control", required: true, placeholder: "Ej: Préstamo para el coche" %>
  </div>

  <div class="row">
    <div class="col-md-6 mb-3">
      <%= f.label :debt_type, "Tipo", class: "form-label" %>
      <%= f.select :debt_type, [["Por pagar", "to_pay"], ["Por cobrar", "to_receive"]], { include_blank: "Selecciona..." }, class: "form-select", required: true %>
    </div>

    <div class="col-md-6 mb-3">
      <%= f.label :person_name, "Persona", class: "form-label" %>
      <%= f.text_field :person_name, class: "form-control", required: true, placeholder: "Nombre de la persona" %>
    </div>
  </div>

  <div class="row">
    <div class="col-md-6 mb-3">
      <%= f.label :normalized_amount, "Monto", class: "form-label" %>
      <%= f.number_field :normalized_amount,
                         class: "form-control",
                         step: 0.01,
                         required: true,
                         placeholder: "0.00",
                         value: debt.normalized_amount %>
    </div>

    <div class="col-md-3 mb-3">
      <%= f.label :amount_currency, "Moneda", class: "form-label" %>
      <%= f.select :amount_currency, ["CUP", "USD", "EUR", "MXN"], {}, class: "form-select" %>
    </div>

    <div class="col-md-3 mb-3">
      <%= f.label :due_date, "Vence", class: "form-label" %>
      <%= f.date_field :due_date, class: "form-control" %>
    </div>
  </div>

  <div class="mb-3">
    <%= f.label :notes, "Notas", class: "form-label" %>
    <%= f.text_area :notes, class: "form-control", rows: 3, placeholder: "Notas opcionales..." %>
  </div>

  <%= f.submit "Guardar", class: "btn btn-primary" %>
  <%= link_to "Cancelar", debts_path, class: "btn btn-secondary" %>
<% end %>
