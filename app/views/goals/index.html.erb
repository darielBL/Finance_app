<h1 class="mb-4">Metas de Ahorro</h1>

<%= link_to new_goal_path, class: "btn btn-primary mb-3" do %>
  <i class="fas fa-plus me-1"></i>Nueva Meta
<% end %>

<% if @active_goals.any? %>
  <h5 class="mb-3"><i class="fas fa-spinner text-primary me-1"></i>En Progreso</h5>
  <div class="row g-4 mb-4">
    <% @active_goals.each do |goal| %>
      <div class="col-md-6 col-lg-4">
        <div class="card h-100">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-2">
              <h5 class="card-title mb-0">
                <%= link_to goal.name, goal_path(goal), class: "text-decoration-none" %>
              </h5>
              <span class="badge bg-primary"><%= goal.progress_percentage %>%</span>
            </div>

            <div class="progress mb-2" style="height: 8px;">
              <div class="progress-bar bg-success" role="progressbar"
                   style="width: <%= goal.progress_percentage %>%"
                   aria-valuenow="<%= goal.progress_percentage %>" aria-valuemin="0" aria-valuemax="100">
              </div>
            </div>

            <div class="d-flex justify-content-between small">
              <span class="text-muted"><%= goal.current_amount.format %></span>
              <span class="fw-bold"><%= goal.target_amount.format %></span>
            </div>

            <div class="mt-2 small text-muted">
              <% if goal.deadline %>
                <i class="fas fa-calendar-alt me-1"></i>
                <% days = goal.days_remaining %>
                <% if days && days > 0 %>
                  <%= days %> días restantes
                <% elsif days && days <= 0 %>
                  <span class="text-danger">Fecha vencida</span>
                <% end %>
              <% end %>
              <% if goal.source.present? %>
                <br><i class="fas fa-tag me-1"></i><%= goal.source %>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% end %>

<% if @completed_goals.any? %>
  <h5 class="mb-3"><i class="fas fa-check-circle text-success me-1"></i>Completadas</h5>
  <div class="row g-4 mb-4">
    <% @completed_goals.each do |goal| %>
      <div class="col-md-6 col-lg-4">
        <div class="card h-100 border-success">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-2">
              <h5 class="card-title mb-0">
                <%= link_to goal.name, goal_path(goal), class: "text-decoration-none text-success" %>
                <i class="fas fa-check-circle text-success ms-1"></i>
              </h5>
              <span class="badge bg-success">100%</span>
            </div>
            <div class="progress mb-2" style="height: 8px;">
              <div class="progress-bar bg-success" role="progressbar" style="width: 100%"></div>
            </div>
            <div class="d-flex justify-content-between small">
              <span class="text-muted"><%= goal.current_amount.format %></span>
              <span class="fw-bold"><%= goal.target_amount.format %></span>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% end %>

<% if @goals.empty? %>
  <div class="text-center py-5 text-muted">
    <i class="fas fa-bullseye fa-3x mb-3"></i>
    <p>No hay metas de ahorro. ¡Crea tu primera meta!</p>
  </div>
<% end %>
