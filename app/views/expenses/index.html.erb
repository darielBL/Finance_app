<h1 class="mb-4">Gestión de Gastos</h1>

<!-- Tabs -->
<ul class="nav nav-tabs mb-4" id="expenseTabs" role="tablist">
  <li class="nav-item" role="presentation">
    <button class="nav-link active" id="unique-tab" data-bs-toggle="tab" data-bs-target="#unique" type="button" role="tab">
      <i class="fas fa-receipt me-1"></i> Gastos Únicos
    </button>
  </li>
  <li class="nav-item" role="presentation">
    <button class="nav-link" id="recurring-tab" data-bs-toggle="tab" data-bs-target="#recurring" type="button" role="tab">
      <i class="fas fa-calendar-alt me-1"></i> Gastos Recurrentes
    </button>
  </li>
</ul>

<!-- Contenido de tabs -->
<div class="tab-content">
  <!-- Pestaña: Gastos Únicos -->
  <div class="tab-pane fade show active" id="unique" role="tabpanel">
    <div class="mb-3">
      <%= link_to new_expense_path, class: "btn btn-primary" do %>
        <i class="fas fa-plus me-1"></i>Nuevo Gasto Único
      <% end %>
    </div>
    <%= render "expenses_table", expenses: @expenses %>
  </div>

  <!-- Pestaña: Gastos Recurrentes -->
  <div class="tab-pane fade" id="recurring" role="tabpanel">
    <div class="mb-3">
      <%= link_to new_recurring_expense_path, class: "btn btn-outline-primary" do %>
        <i class="fas fa-plus me-1"></i>Nuevo Gasto Recurrente
      <% end %>
    </div>
    <%= render "recurring_expenses_table", recurring_expenses: @recurring_expenses %>
  </div>
</div>