<h1>Mis Gastos</h1>

<div class="mb-3">
  <%= link_to "Nuevo Gasto", new_expense_path, class: "btn btn-primary" %>
</div>

<div class="table-responsive">
  <table class="table table-striped">
    <thead>
    <tr>
      <th>Descripción</th>
      <th>Monto</th>
      <th>Categoría</th>
      <th>Fuente de Ingreso</th>
      <th>Fecha</th>
      <th>Acciones</th>
    </tr>
    </thead>
    <tbody>
    <% @expenses.each do |expense| %>
      <tr>
        <td><%= expense.description %></td>
        <td><%= expense.amount.format %></td>
        <td><%= expense.category.name %></td>
        <td>
          <% if expense.income_source %>
          <span class="badge bg-info text-dark">
            <i class="fas fa-dollar-sign me-1"></i><%= expense.income_source.name %>
          </span>
          <% else %>
            <span class="badge bg-light text-muted">Sin relacionar</span>
          <% end %>
        </td>
        <td><%= expense.formatted_date %></td>
        <td class="text-nowrap text-end">
          <%= link_to edit_expense_path(expense), class: "btn btn-sm btn-outline-primary me-1", title: "Editar" do %>
            <i class="fas fa-edit"></i>
          <% end %>
          <%= button_to expense_path(expense), method: :delete, class: "btn btn-sm btn-outline-danger", title: "Eliminar", form: { class: "d-inline" }, data: { turbo_confirm: "¿Estás seguro?" } do %>
            <i class="fas fa-trash-alt"></i>
          <% end %>
        </td>
      </tr>
    <% end %>
    </tbody>
  </table>
</div>

<%= paginate @expenses %>

<%= link_to "Volver al Dashboard", dashboard_path, class: "btn btn-secondary mt-3" %>