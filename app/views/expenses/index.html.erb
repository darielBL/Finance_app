<h1>Mis Gastos</h1>

<div class="mb-3">
  <%= link_to "Nuevo Gasto", new_expense_path, class: "btn btn-primary" %>
</div>

<div class="table-responsive">
  <table class="table table-striped">
    <thead>
    <tr>
      <th>Descripción</th>
      <th>Monto</th>
      <th>Categoría</th>
      <th>Fecha</th>
      <th>Acciones</th>
    </tr>
    </thead>
    <tbody>
    <% @expenses.each do |expense| %>
      <tr>
        <td><%= expense.description %></td>
        <td><%= expense.amount.format %></td>
        <td><%= expense.category.name %></td>
        <td><%= expense.formatted_date %></td>
        <td>
          <%= link_to "Editar", edit_expense_path(expense), class: "btn btn-sm btn-warning" %>
          <%= button_to "Eliminar", expense_path(expense), method: :delete, class: "btn btn-sm btn-danger", data: { turbo_confirm: "¿Estás seguro?" } %>
        </td>
      </tr>
    <% end %>
    </tbody>
  </table>
</div>

<%= paginate @expenses %>

<%= link_to "Volver al Dashboard", dashboard_path, class: "btn btn-secondary mt-3" %>