<%= form_with model: expense, local: true do |f| %>
  <% if expense.errors.any? %>
    <div class="alert alert-danger">
      <h4><%= pluralize(expense.errors.count, "error") %> impidieron guardar este gasto:</h4>
      <ul>
        <% expense.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :description, "Descripción", class: "form-label" %>
    <%= f.text_field :description, class: "form-control", required: true %>
  </div>

  <div class="row">
    <div class="col-md-6 mb-3">
      <%= f.label :normalized_amount, "Monto", class: "form-label" %>
      <%= f.number_field :normalized_amount,
                         class: "form-control",
                         step: 0.1,
                         required: true,
                         placeholder: "0.00",
                         value: @expense.normalized_amount %>
    </div>

    <div class="col-md-6 mb-3">
      <%= f.label :amount_currency, "Moneda", class: "form-label" %>
      <%= f.select :amount_currency, ["CUP", "USD", "EUR"], {}, class: "form-select" %>
    </div>
  </div>


  <div class="mb-3">
    <%= f.label :category_id, "Categoría", class: "form-label" %>
    <%= f.select :category_id, @categories.map { |c| [c.name, c.id] }, { include_blank: "Selecciona una categoría" }, class: "form-select", required: true %>
  </div>

  <div class="mb-3">
    <%= f.label :spent_at, "Fecha del Gasto", class: "form-label" %>
    <%= f.date_field :spent_at, class: "form-control", required: true, max: Date.current %>
  </div>

  <%= f.submit "Guardar", class: "btn btn-primary" %>
  <%= link_to "Cancelar", expenses_path, class: "btn btn-secondary" %>
<% end %>