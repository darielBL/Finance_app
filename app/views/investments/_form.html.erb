<%= form_with model: investment, local: true do |f| %>
  <% if investment.errors.any? %>
    <div class="alert alert-danger">
      <h4><%= pluralize(investment.errors.count, "error") %> impidieron guardar esta inversión:</h4>
      <ul>
        <% investment.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :name, "Nombre de la Inversión", class: "form-label" %>
    <%= f.text_field :name, class: "form-control", required: true, placeholder: "Ej: Compra de laptops, Criptomonedas, Plazo fijo" %>
  </div>

  <div class="row">
    <div class="col-md-6 mb-3">
      <%= f.label :normalized_amount, "Monto Invertido", class: "form-label" %>
      <%= f.number_field :normalized_amount,
                         class: "form-control",
                         step: 0.01,
                         required: true,
                         placeholder: "0.00",
                         value: investment.normalized_amount %>
      <small class="text-muted">Ejemplo: 10000.00</small>
    </div>

    <div class="col-md-6 mb-3">
      <%= f.label :amount_currency, "Moneda", class: "form-label" %>
      <%= f.select :amount_currency, ["CUP", "USD", "EUR", "MXN"], {}, class: "form-select" %>
    </div>
  </div>

  <div class="mb-3">
    <%= f.label :invested_at, "Fecha de la Inversión", class: "form-label" %>
    <%= f.date_field :invested_at, class: "form-control", required: true, max: Date.current %>
  </div>

  <%= f.submit "Guardar", class: "btn btn-primary" %>
  <%= link_to "Cancelar", investments_path, class: "btn btn-secondary" %>
<% end %>