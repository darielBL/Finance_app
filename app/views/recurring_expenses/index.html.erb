<h1 class="mb-4">Gastos Recurrentes</h1>

<%= link_to new_recurring_expense_path, class: "btn btn-primary mb-3" do %>
  <i class="fas fa-plus me-1"></i>Nuevo Gasto Recurrente
<% end %>

<div class="table-responsive">
  <table class="table table-striped">
    <thead>
    <tr>
      <th>Nombre</th>
      <th class="text-end">Mensual</th>
      <th>Día</th>
      <th class="text-end">Mes actual</th>
      <th>Estado</th>
      <th class="text-end">Acciones</th>
    </tr>
    </thead>
    <tbody>
    <% @recurring_expenses.each do |expense| %>
      <% current_record = expense.current_month_record %>
      <tr>
        <td><i class="fas fa-sync-alt text-info me-2"></i><%= expense.name %></td>
        <td class="text-end"><%= expense.estimated_amount.format %></td>
        <td><%= expense.due_day.present? ? "Día #{expense.due_day}" : "Variable" %></td>
        <td class="text-end">
          <% if current_record&.actual_amount_cents %>
            <%= Money.new(current_record.actual_amount_cents, current_record.actual_amount_currency).format %>
          <% else %>
            <span class="badge bg-warning">Pendiente</span>
          <% end %>
        </td>
        <td>
          <% if current_record&.actual_amount_cents %>
            <% diff = current_record.actual_amount_cents - expense.estimated_amount_cents %>
            <% if diff > 0 %>
              <span class="badge bg-danger">+<%= Money.new(diff, current_record.actual_amount_currency).format %></span>
            <% elsif diff < 0 %>
              <span class="badge bg-success"><%= Money.new(diff, current_record.actual_amount_currency).format %></span>
            <% else %>
              <span class="badge bg-info">Cumplido</span>
            <% end %>
          <% else %>
            <span class="badge bg-secondary">Sin registrar</span>
          <% end %>
        </td>
        <td class="text-nowrap text-end">
          <%= link_to edit_recurring_expense_path(expense), class: "btn btn-sm btn-outline-primary me-1", title: "Editar" do %>
            <i class="fas fa-edit"></i>
          <% end %>
          <%= link_to new_recurring_expense_recurring_expense_record_path(expense, month: Date.current.beginning_of_month), class: "btn btn-sm btn-outline-info me-1", title: "Registrar pago" do %>
            <i class="fas fa-receipt"></i>
          <% end %>
          <%= button_to recurring_expense_path(expense), method: :delete, class: "btn btn-sm btn-outline-danger", title: "Eliminar", form: { class: "d-inline" }, data: { turbo_confirm: "¿Eliminar este gasto recurrente?" } do %>
            <i class="fas fa-trash-alt"></i>
          <% end %>
        </td>
        </td>
    </tr>
    <% end %>
    </tbody>
  </table>
</div>

<%= link_to "Volver a Gastos", expenses_path, class: "btn btn-secondary mt-3" %>