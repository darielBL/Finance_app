<h1>Registrar Ingreso - <%= @income.name %></h1>
<p class="text-muted">Mes: <%= l(@record.month, format: "%B %Y") %></p>

<%= form_with model: [:income, @record], local: true do |f| %>
  <div class="card mb-4">
    <div class="card-body">
      <p>Monto estimado: <strong><%= @income.amount.format %></strong></p>
    </div>
  </div>

  <div class="row">
    <div class="col-md-6 mb-3">
      <%= f.label :normalized_amount, "Monto Real Recibido", class: "form-label" %>
      <%= f.number_field :normalized_amount,
                         class: "form-control",
                         step: 0.01,
                         required: true,
                         placeholder: "0.00",
                         value: @record.normalized_amount %>
      <small class="text-muted">Ejemplo: 25000.00</small>
    </div>
    <div class="col-md-6 mb-3">
      <%= f.label :actual_amount_currency, "Moneda", class: "form-label" %>
      <%= f.select :actual_amount_currency, ["CUP", "USD", "EUR", "MXN"], { selected: @income.amount_currency }, class: "form-select" %>
    </div>
  </div>

  <%= f.hidden_field :actual_amount_cents %>

  <div class="mb-3">
    <%= f.label :received_date, "Fecha de cobro", class: "form-label" %>
    <%= f.date_field :received_date, class: "form-control", value: Date.current, max: Date.current %>
    <small class="text-muted">¿Cu&aacute;ndo recibiste este ingreso?</small>
  </div>

  <div class="mb-3">
    <%= f.label :notes, "Notas (opcional)", class: "form-label" %>
    <%= f.text_area :notes, class: "form-control", rows: 3, placeholder: "¿Hubo alg&uacute;n cambio en este ingreso?" %>
  </div>

  <%= f.submit "Registrar Ingreso", class: "btn btn-primary" %>
  <%= link_to "Cancelar", incomes_path, class: "btn btn-secondary" %>
<% end %>
