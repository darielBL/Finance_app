<%= form_with model: [goal, contribution], local: true do |f| %>
  <% if contribution.errors.any? %>
    <div class="alert alert-danger">
      <h4><%= pluralize(contribution.errors.count, "error") %> impidieron guardar el aporte:</h4>
      <ul>
        <% contribution.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row">
    <div class="col-md-6 mb-3">
      <%= f.label :normalized_amount, "Monto", class: "form-label" %>
      <%= f.number_field :normalized_amount,
                         class: "form-control",
                         step: 0.01,
                         required: true,
                         placeholder: "0.00",
                         value: contribution.normalized_amount %>
    </div>

    <div class="col-md-3 mb-3">
      <%= f.label :amount_currency, "Moneda", class: "form-label" %>
      <%= f.select :amount_currency, ["CUP", "USD", "EUR", "MXN"], {}, class: "form-select" %>
    </div>

    <div class="col-md-3 mb-3">
      <%= f.label :contributed_at, "Fecha", class: "form-label" %>
      <%= f.date_field :contributed_at, class: "form-control", required: true %>
    </div>
  </div>

  <div class="mb-3">
    <%= f.label :source, "Fuente (opcional)", class: "form-label" %>
    <%= f.text_field :source,
                     list: "contribution_source_options",
                     class: "form-control",
                     placeholder: "¿De dónde salió este dinero?" %>
    <datalist id="contribution_source_options">
      <% current_user.incomes.distinct.pluck(:source).compact.each do |source| %>
        <option value="<%= source %>">
      <% end %>
    </datalist>
  </div>

  <div class="mb-3">
    <%= f.label :notes, "Notas", class: "form-label" %>
    <%= f.text_area :notes, class: "form-control", rows: 2, placeholder: "Notas opcionales..." %>
  </div>

  <%= f.hidden_field :amount_cents %>

  <%= f.submit "Guardar Aporte", class: "btn btn-success" %>
  <%= link_to "Cancelar", goal_path(goal), class: "btn btn-secondary" %>
<% end %>
