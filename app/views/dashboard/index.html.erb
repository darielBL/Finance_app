<!-- Header con bienvenida -->
<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
  <div>
    <h1 class="h2 mb-0">
      <i class="fas fa-chart-pie text-primary me-2"></i>
      Bienvenido, <span class="text-primary"><%= current_user.email.split('@').first.capitalize %></span>
    </h1>
    <p class="text-muted mt-2">Aquí tienes un resumen de tus finanzas</p>
  </div>
  <div class="text-muted">
    <i class="fas fa-calendar-alt me-1"></i>
    <%= @date_range.first.strftime("%d/%b/%Y") %> - <%= @date_range.last.strftime("%d/%b/%Y") %>
  </div>
</div>

<!-- Filtros -->
<div class="card mb-4">
  <div class="card-body">
    <%= form_with url: dashboard_path, method: :get, local: true, class: "row g-3" do |f| %>
      <div class="col-md-6">
        <%= f.label :currency, "<i class='fas fa-dollar-sign me-1'></i> Moneda".html_safe, class: "form-label" %>
        <%= f.select :currency, @available_currencies, { selected: @currency }, { class: "form-select", onchange: "this.form.submit()" } %>
      </div>
      <div class="col-md-6">
        <%= f.label :period, "<i class='fas fa-clock me-1'></i> Período".html_safe, class: "form-label" %>
        <%= f.select :period, options_for_select([["Mes Actual", "current_month"], ["Mes Pasado", "last_month"], ["Últimos 3 Meses", "last_3_months"], ["Año Actual", "current_year"]], @period), {}, { class: "form-select", onchange: "this.form.submit()" } %>
      </div>
    <% end %>
  </div>
</div>


<!-- Cards de resumen -->
<div class="row g-4 mb-4">
  <!-- 1. Ingresos Activos (fondo verde suave) -->
  <div class="col-md-3">
    <div class="card border-0 shadow-sm h-100" style="background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <p class="text-success small mb-1 fw-semibold">INGRESOS ACTIVOS</p>
            <h3 class="mb-0 text-success"><%= @total_active_income_net.format %></h3>
            <small class="text-muted">en <%= @currency %></small>
          </div>
          <div class="bg-success bg-opacity-10 rounded-circle p-3">
            <i class="fas fa-arrow-down text-success fa-2x"></i>
          </div>
        </div>
        <hr class="my-2">
        <div class="small">
          <span class="text-muted">Fuentes activas: </span>
          <strong class="text-success"><%= @active_incomes.count %></strong>
        </div>
      </div>
    </div>
  </div>

  <!-- 2. Gastos Totales (fondo rojo suave) -->
  <div class="col-md-3">
    <div class="card border-0 shadow-sm h-100" style="background: linear-gradient(135deg, #ffebee 0%, #ffcdd2 100%);">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <p class="text-danger small mb-1 fw-semibold">GASTOS TOTALES</p>
            <h3 class="mb-0 text-danger"><%= @total_expenses.format %></h3>
            <small class="text-muted">en <%= @currency %></small>
          </div>
          <div class="bg-danger bg-opacity-10 rounded-circle p-3">
            <i class="fas fa-arrow-up text-danger fa-2x"></i>
          </div>
        </div>
        <hr class="my-2">
        <div class="small">
          <span class="text-muted">vs mes pasado</span>
          <span class="text-danger"><i class="fas fa-arrow-up me-1"></i>2.1%</span>
        </div>
      </div>
    </div>
  </div>

  <!-- 3. Patrimonio Total (fondo degradado azul de tu paleta) -->
  <div class="col-md-3">
    <div class="card border-0 shadow-sm h-100" style="background: linear-gradient(135deg, #001d39 0%, #0a4174 100%);">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <p class="text-white small mb-1 fw-semibold opacity-75">PATRIMONIO TOTAL</p>
            <h3 class="mb-0 fw-bold text-white"><%= @total_wealth.format %></h3>
            <small class="text-white opacity-75">capital + ingresos</small>
          </div>
          <div class="bg-white bg-opacity-25 rounded-circle p-3">
            <i class="fas fa-chart-line text-white fa-2x"></i>
          </div>
        </div>
        <hr class="my-2 bg-white bg-opacity-25">
        <div class="small text-white opacity-75">
          Disponible para gastar/invertir
        </div>
      </div>
    </div>
  </div>

  <!-- 4. Gasto / Ingreso (fondo neutro) -->
  <div class="col-md-3">
    <div class="card border-0 shadow-sm h-100" style="background: #f8f9fa;">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <p class="text-muted small mb-1 fw-semibold">GASTO / INGRESO</p>
            <% ratio = @total_active_income.cents > 0 ? (@total_expenses.cents.to_f / @total_active_income.cents * 100).round(1) : 0 %>
            <h3 class="mb-0"><%= ratio %>%</h3>
            <small class="text-muted">del ingreso gastado</small>
          </div>
          <div class="bg-warning bg-opacity-10 rounded-circle p-3">
            <i class="fas fa-chart-line text-warning fa-2x"></i>
          </div>
        </div>
        <hr class="my-2">
        <div class="progress" style="height: 4px;">
          <div class="progress-bar <%= ratio > 70 ? 'bg-danger' : 'bg-success' %>" role="progressbar" style="width: <%= ratio %>%" aria-valuenow="<%= ratio %>" aria-valuemin="0" aria-valuemax="100"></div>
        </div>
        <small class="text-muted"><%= ratio <= 50 ? '✅ Excelente ahorro' : (ratio <= 80 ? '⚠️ Controla gastos' : '🔴 Alerta roja') %></small>
      </div>
    </div>
  </div>
</div>
<!-- Gráfico de barras: Ingresado vs Gastado por Origen -->
<div class="row g-4 mb-4">
  <div class="col-12">
    <div class="card h-100">
      <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <div><i class="fas fa-chart-bar me-2 text-primary"></i><strong>Ingresado vs Gastado por Origen</strong></div>
        <div><span class="badge bg-info"><%= @currency %></span></div>
      </div>
      <div class="card-body">
        <% has_data = @income_vs_expense_chart.any? { |s| s[:data].values.any? { |v| v > 0 } } %>
        <% if has_data %>
          <div style="height: 350px;">
            <%= column_chart @income_vs_expense_chart,
                             colors: ["#0a4174", "#dc3545"],
                             library: {
                               animation: { duration: 600 },
                               tooltips: {
                                 callbacks: {
                                   label: "function(tooltipItem, data) {
                                     var dataset = data.datasets[tooltipItem.datasetIndex];
                                     var value = dataset.data[tooltipItem.dataIndex];
                                     return dataset.label + ': ' + value.toLocaleString('es-CU', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' ' + '#{@currency}';
                                   }"
                                 },
                                 backgroundColor: "rgba(0,0,0,0.8)",
                                 cornerRadius: 6,
                                 padding: 10
                               },
                               legend: {
                                 position: 'bottom',
                                 labels: {
                                   usePointStyle: true,
                                   padding: 16,
                                   fontSize: 12
                                 }
                               },
                               scales: {
                                 xAxes: [{
                                   gridLines: { display: false },
                                   ticks: { maxRotation: 30 }
                                 }],
                                 yAxes: [{
                                   gridLines: {
                                     color: "rgba(0,0,0,0.06)",
                                     zeroLineColor: "rgba(0,0,0,0.1)"
                                   },
                                   ticks: {
                                     callback: "function(value) { return value.toLocaleString('es-CU', { minimumFractionDigits: 0 }); }"
                                   }
                                 }]
                               }
                             },
                             height: "350px",
                             dataset: { borderRadius: 5 } %>
          </div>
        <% else %>
          <div class="text-center py-5">
            <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
            <p class="text-muted mb-0">No hay datos en <%= @currency %> para el período seleccionado</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<!-- Gastos por Fuente (Ingresos + Capital Inicial) -->
<div class="row mt-4">
  <div class="col-12">
    <div class="card" id="card-origen-gastos">
      <div class="card-header bg-white d-flex justify-content-between align-items-center collapsible">
        <div><i class="fas fa-chart-line me-2 text-primary"></i><strong>Origen de los Gastos</strong></div>
        <div><span class="badge bg-info me-2"><%= @currency %></span><i class="fas fa-chevron-down collapse-icon text-muted"></i></div>
      </div>
      <div class="card-body">
        <% if @all_sources.present? && @all_sources.values.sum > 0 %>
          <div style="height: 350px;">
            <%= pie_chart @all_sources,
                          colors: ["#001d39", "#0a4174", "#49769f", "#4e8ea2", "#6ea2b3", "#7bbde8", "#bdd8e9", "#f59e0b"],
                          library: {
                            tooltips: {
                              callbacks: {
                                label: "function(tooltipItem, data) {
                                  var dataset = data.datasets[tooltipItem.datasetIndex];
                                  var total = dataset.data.reduce(function(a, b) { return a + b; }, 0);
                                  var value = dataset.data[tooltipItem.index];
                                  var pct = ((value / total) * 100).toFixed(1);
                                  var label = data.labels[tooltipItem.index] || '';
                                  return label + ': ' + value.toLocaleString('es-CU', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' ' + '#{@currency}' + ' (' + pct + '%)';
                                }"
                              }
                            },
                            legend: { position: 'bottom' }
                          },
                          height: "350px" %>
          </div>
        <% else %>
          <div class="text-center py-5">
            <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
            <p class="text-muted mb-0">No hay gastos registrados en <%= @currency %></p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<!-- Tasas de Cambio - Mercado Informal -->
<div class="row mt-4" id="exchange_rates_chart">
  <div class="col-12">
    <div class="card">
      <div class="card-header bg-white d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div><i class="fas fa-chart-line me-2 text-warning"></i><strong>Tasas de Cambio - Mercado Informal (CUP)</strong></div>
        <div class="d-flex align-items-center gap-2 flex-wrap">
          <% periodos = [["1S", "1W"], ["2S", "2W"], ["1M", "1M"]] %>
          <% periodos.each do |label, value| %>
            <%= link_to label,
                        dashboard_path(rate_period: value, currency: @currency, period: @period, anchor: 'exchange_rates_chart'),
                        class: "btn btn-sm #{@rate_period == value ? 'btn-warning' : 'btn-outline-secondary'}",
                        style: "font-size: 0.75rem; padding: 0.2rem 0.5rem;" %>
          <% end %>
          <% if @exchange_rates.any? %>
            <small class="text-muted ms-1"><%= @rate_date_from.strftime("%d/%b") %> - <%= @exchange_rates.first.date.strftime("%d/%b/%Y") %></small>
          <% end %>
          <span class="badge bg-secondary">elTOQUE</span>
        </div>
      </div>
        <div class="card-body">
          <% has_rates = @exchange_rates.present? && @exchange_rates_chart.any? { |s| s[:data].any? { |_d, v| v.present? } } %>
          <% if has_rates %>
            <div style="height: 350px;">
              <%= line_chart @exchange_rates_chart,
                             colors: ["#28a745", "#007bff", "#ffc107", "#dc3545"],
                             library: {
                               animation: { duration: 600 },
                               tooltips: {
                                 callbacks: {
                                   label: "function(tooltipItem, data) {
                                     var dataset = data.datasets[tooltipItem.datasetIndex];
                                     var value = dataset.data[tooltipItem.dataIndex];
                                     return dataset.label + ': ' + value.toLocaleString('es-CU', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' CUP';
                                   }"
                                 },
                                 backgroundColor: "rgba(0,0,0,0.8)",
                                 cornerRadius: 6,
                                 padding: 10
                               },
                               legend: {
                                 position: 'bottom',
                                 labels: { usePointStyle: true, padding: 16 }
                               },
                                 scales: {
                                   x: {
                                     grid: { display: false },
                                     ticks: {
                                       autoSkip: false,
                                       maxRotation: 45,
                                       minRotation: 0
                                     }
                                   },
                                  y: {
                                    min: @chart_y_min,
                                    ticks: {
                                      stepSize: 5,
                                      callback: "function(value) { return value.toLocaleString('es-CU', { minimumFractionDigits: 0 }); }"
                                    },
                                    grid: { color: "rgba(0,0,0,0.06)" },
                                    title: {
                                      display: true,
                                      text: 'CUP',
                                      font: { weight: 'bold' }
                                    }
                                  }
                                }
                             },
                             height: "350px",
                             dataset: { fill: false, borderWidth: 2 } %>
            </div>
          <% else %>
          <div class="text-center py-5">
            <i class="fas fa-clock fa-3x text-muted mb-3"></i>
            <p class="text-muted mb-0">Esperando datos de elTOQUE...</p>
            <small class="text-muted">Configura <code>EL_TOQUE_API_TOKEN</code> cuando recibas tu token de la API</small>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<!-- Próximos Ingresos Recurrentes -->
<div class="row mt-4">
  <div class="col-12">
    <div class="card" id="card-ingresos-recurrentes">
      <div class="card-header bg-white d-flex justify-content-between align-items-center collapsible">
        <div><i class="fas fa-calendar-alt me-2 text-success"></i><strong>Próximos Ingresos Recurrentes - <%= Date.current.strftime("%B %Y") %></strong></div>
        <div><i class="fas fa-chevron-down collapse-icon text-muted"></i></div>
      </div>
      <div class="card-body p-0">
        <div class="list-group list-group-flush">
          <% current_user.incomes.recurring.ordered.each do |income| %>
            <% current_record = income.current_month_record %>
            <div class="list-group-item d-flex justify-content-between align-items-center">
              <div>
                <i class="fas fa-sync-alt text-success me-2"></i>
                <strong><%= income.name %></strong>
                <small class="text-muted ms-2">
                  <% if income.due_day %>
                    <i class="fas fa-calendar-day me-1"></i>D&iacute;a <%= income.due_day %>
                  <% else %>
                    <i class="fas fa-calendar-week me-1"></i>Fecha variable
                  <% end %>
                </small>
              </div>
              <div>
                <span class="badge bg-success me-2"><%= income.amount.format %></span>
                <% if current_record && current_record.actual_amount_cents %>
                  <span class="badge bg-info"><i class="fas fa-check me-1"></i>Registrado</span>
                <% else %>
                  <%= link_to new_income_income_record_path(income, month: Date.current.beginning_of_month), class: "btn btn-sm btn-outline-success" do %>
                    <i class="fas fa-receipt me-1"></i>Registrar
                  <% end %>
                <% end %>
              </div>
            </div>
          <% end %>
          <% if current_user.incomes.recurring.empty? %>
            <div class="text-center py-4">
              <i class="fas fa-calendar-plus fa-2x text-muted mb-2"></i>
              <p class="text-muted mb-0">No hay ingresos recurrentes configurados</p>
              <%= link_to "Agregar ingreso recurrente", new_income_path(recurring: true), class: "btn btn-sm btn-success mt-2" %>
            </div>
          <% end %>
         </div>
      </div>
    </div>
  </div>
</div>

<!-- Próximos Gastos Recurrentes -->
<div class="row mt-4">
  <div class="col-12">
    <div class="card" id="card-gastos-recurrentes">
      <div class="card-header bg-white d-flex justify-content-between align-items-center collapsible">
        <div><i class="fas fa-calendar-alt me-2 text-primary"></i><strong>Próximos Gastos Recurrentes - <%= Date.current.strftime("%B %Y") %></strong></div>
        <div><i class="fas fa-chevron-down collapse-icon text-muted"></i></div>
      </div>
      <div class="card-body p-0">
        <div class="list-group list-group-flush">
          <% current_user.expenses.recurring.ordered_recurring.each do |expense| %>
            <% current_record = expense.current_month_record %>
            <div class="list-group-item d-flex justify-content-between align-items-center">
              <div>
                <i class="fas fa-sync-alt text-info me-2"></i>
                <strong><%= expense.name %></strong>
                <small class="text-muted ms-2">
                  <% if expense.due_day %>
                    <i class="fas fa-calendar-day me-1"></i>Día <%= expense.due_day %>
                  <% else %>
                    <i class="fas fa-calendar-week me-1"></i>Fecha variable
                  <% end %>
                </small>
              </div>
              <div>
                <span class="badge bg-primary me-2"><%= expense.amount.format %></span>
                <% if current_record && current_record.actual_amount_cents %>
                  <span class="badge bg-success"><i class="fas fa-check me-1"></i>Pagado</span>
                <% else %>
                  <%= link_to new_expense_expense_record_path(expense, month: Date.current.beginning_of_month), class: "btn btn-sm btn-outline-primary" do %>
                    <i class="fas fa-receipt me-1"></i>Registrar
                  <% end %>
                <% end %>
              </div>
            </div>
          <% end %>
          <% if current_user.expenses.recurring.empty? %>
            <div class="text-center py-4">
              <i class="fas fa-calendar-plus fa-2x text-muted mb-2"></i>
              <p class="text-muted mb-0">No hay gastos recurrentes configurados</p>
              <%= link_to "Agregar gasto recurrente", new_expense_path(recurring: true), class: "btn btn-sm btn-primary mt-2" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>


<!-- Metas de Ahorro -->
<% if @goals.present? %>
  <div class="row mt-4">
    <div class="col-12">
      <div class="card">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
          <div><i class="fas fa-bullseye me-2 text-success"></i><strong>Metas de Ahorro</strong></div>
          <%= link_to goals_path, class: "btn btn-sm btn-outline-success" do %>
            <i class="fas fa-eye me-1"></i>Ver todas
          <% end %>
        </div>
        <div class="card-body">
          <div class="row g-3">
            <% @goals.each do |goal| %>
              <div class="col-md-6 col-lg-4">
                <div class="d-flex justify-content-between align-items-start mb-1">
                  <strong class="small"><%= link_to goal.name, goal, class: "text-decoration-none" %></strong>
                  <span class="badge bg-primary" style="font-size: 0.7rem;"><%= goal.progress_percentage %>%</span>
                </div>
                <div class="progress mb-1" style="height: 6px;">
                  <div class="progress-bar bg-success" role="progressbar"
                       style="width: <%= goal.progress_percentage %>%"></div>
                </div>
                <div class="d-flex justify-content-between small text-muted">
                  <span><%= goal.current_amount.format %></span>
                  <span><%= goal.target_amount.format %></span>
                </div>
              </div>
            <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>



<!-- Últimos gastos -->
<% if @expenses.present? %>
  <div class="row mt-4">
    <div class="col-12">
      <div class="card" id="card-ultimos-gastos">
        <div class="card-header bg-white d-flex justify-content-between align-items-center collapsible">
          <div><i class="fas fa-history me-2 text-primary"></i><strong>Últimos Gastos</strong></div>
          <div><i class="fas fa-chevron-down collapse-icon text-muted"></i></div>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead class="table-light">
              <tr><th>Fecha</th><th>Descripción</th><th>Categoría</th><th>Fuente</th><th class="text-end">Monto</th></tr>
              </thead>
              <tbody>
              <% @expenses.limit(10).each do |expense| %>
                <tr>
                  <td><%= expense.spent_at.strftime("%d/%m/%Y") %></td>
                  <td><%= expense.name %></td>
                  <td><span class="badge bg-secondary"><%= expense.category.name %></span></td>
                  <td>
                    <% if expense.income %>
                      <span class="badge bg-info text-dark"><i class="fas fa-dollar-sign me-1"></i><%= expense.income.name %></span>
                    <% else %>
                      <span class="badge bg-light text-muted">Sin relacionar</span>
                    <% end %>
                  </td>
                  <td class="text-end fw-bold"><%= expense.amount.format %></td>
                </tr>
              <% end %>
              </tbody>
            </table>
          </div>
          <% if @expenses.count > 10 %>
            <div class="text-center p-3">
              <p class="text-muted mb-0">Mostrando 10 de <%= @expenses.count %> gastos</p>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>