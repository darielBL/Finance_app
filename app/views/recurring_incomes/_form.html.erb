<%= form_with model: recurring_income, local: true do |f| %>
  <% if recurring_income.errors.any? %>
    <div class="alert alert-danger">
      <h4><%= pluralize(recurring_income.errors.count, "error") %></h4>
      <ul><% recurring_income.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %></ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :name, "Nombre del Ingreso", class: "form-label" %>
    <%= f.text_field :name, class: "form-control", required: true, placeholder: "Ej: Salario, Freelance, Renta" %>
  </div>

  <div class="row">
    <div class="col-md-6 mb-3">
      <%= f.label :normalized_amount, "Monto Estimado", class: "form-label" %>
      <%= f.number_field :normalized_amount,
                         class: "form-control",
                         step: 0.01,
                         required: true,
                         placeholder: "0.00",
                         value: recurring_income.normalized_amount %>
    </div>
    <div class="col-md-6 mb-3">
      <%= f.label :estimated_amount_currency, "Moneda", class: "form-label" %>
      <%= f.select :estimated_amount_currency, ["CUP", "USD", "EUR", "MXN"], {}, class: "form-select" %>
    </div>
  </div>

  <div class="mb-3">
    <%= f.label :source, "Origen del dinero", class: "form-label" %>
    <%= f.text_field :source,
                     list: "source_options",
                     class: "form-control",
                     placeholder: "Ej: Efectivo, Tarjeta BBVA, Transferencia, PayPal",
                     required: true %>
    <datalist id="source_options">
      <% current_user.income_sources.distinct.pluck(:source).compact.each do |source| %>
        <option value="<%= source %>">
      <% end %>
      <% current_user.recurring_incomes.distinct.pluck(:source).compact.each do |source| %>
        <option value="<%= source %>">
      <% end %>
    </datalist>
    <small class="text-muted">Puedes escribir cualquier origen. Los usados anteriormente aparecerán como sugerencias.</small>
  </div>

  <div class="mb-3">
    <%= f.label :due_day, "Día de cobro", class: "form-label" %>
    <%= f.select :due_day,
                 [["Cualquier día", ""]] + (1..31).map { |d| ["Día #{d}", d] },
                 {},
                 class: "form-select" %>
    <small class="text-muted">¿Qué día del mes sueles recibir este ingreso?</small>
  </div>

  <div class="mb-3">
    <div class="form-check">
      <%= f.check_box :active, class: "form-check-input", checked: true %>
      <%= f.label :active, "¿Activo?", class: "form-check-label" %>
    </div>
    <small class="text-muted">Si está activo, este ingreso se considerará en tus cálculos mensuales</small>
  </div>

  <%= f.hidden_field :estimated_amount_cents %>

  <%= f.submit "Crear Ingreso Recurrente", class: "btn btn-primary" %>
  <%= link_to "Cancelar", recurring_incomes_path, class: "btn btn-secondary" %>
<% end %>