# Gemfile
source "https://rubygems.org"

ruby "3.3.0"  # o la versión que tengas (ajústala si es diferente)

# Bundle edge Rails instead: gem "rails", github: "rails/rails", branch: "main"
gem "rails", "~> 8.0.0"

gem 'puma'

# Database
gem "pg", "~> 1.1"

# Auth
gem "devise", "~> 5.0"

# Money handling
gem "money-rails", "~> 1.12"

# Charts
gem "chartkick", "~> 5.0"
gem "groupdate", "~> 6.4"

# Frontend (Bootstrap 5)
gem "bootstrap", "~> 5.3"
gem "sassc-rails", "~> 2.1"

# Asset pipeline
gem "importmap-rails", "~> 2.0"
gem "sprockets-rails", "~> 3.5"

# Hotwire (para modals y respuestas)
gem "turbo-rails", "~> 2.0"
gem "stimulus-rails", "~> 1.3"

# JSON APIs
gem "jbuilder", "~> 2.13"

# Performance
gem "bootsnap", "~> 1.18", require: false

# Development-only
group :development do
  gem "web-console", "~> 4.2"
  gem "letter_opener", "~> 1.10"  # para ver emails en desarrollo (Devise)
end

# Windows compatibility
gem "tzinfo-data", platforms: %i[ windows jruby ]

# Optional: for faster server restart
gem "spring", group: :development
gem "date_validator", "~> 0.12.0"

gem "kaminari", "~> 1.2"

gem "solid_cache", "~> 1.0"

gem "solid_cable", "~> 3.0"
